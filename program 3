import java.util.ArrayList;
import java.util.Arrays;
import java.util.Collections;

public class Main {

    public static ArrayList<Integer> findLeaders(ArrayList<Integer> list) {
        ArrayList<Integer> leaders = new ArrayList<>();

        int maxFromRight = list.get(list.size() - 1);
        leaders.add(maxFromRight);

        for (int i = list.size() - 2; i >= 0; i--) {
            if (list.get(i) > maxFromRight) {
                maxFromRight = list.get(i);
                leaders.add(maxFromRight);
            }
        }

        Collections.reverse(leaders);

        return leaders;
    }

    public static void main(String[] args) {
        ArrayList<Integer> list = new ArrayList<>(
                Arrays.asList(16, 17, 4, 3, 5, 2));

        ArrayList<Integer> result = findLeaders(list);

        System.out.println("Output: " + result);
    }
}
