import java.util.*;

public class Main {

    public static List<Integer> intersection(int[] arr1, int[] arr2) {
        HashSet<Integer> set1 = new HashSet<>();
        HashSet<Integer> resultSet = new HashSet<>(
        for (int num : arr1) {
            set1.add(num);
        for (int num : arr2) {
            if (set1.contains(num)) {
                resultSet.add(num);
            }
        }

        return new ArrayList<>(resultSet);
    }
